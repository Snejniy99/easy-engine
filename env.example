PORT=3000
DATABASE_URL=postgres://postgres:password@localhost:5432/database
NODE_ENV=development

# Корень файлового хранилища плагинов (по умолчанию <проект>/data/storage). Абсолютный путь или относительно корня проекта:
# STORAGE_ROOT=

# Лимит POST /login, /register, /logout (IP). Число запросов за окно:
# RATE_LIMIT_AUTH_MAX=40
# RATE_LIMIT_AUTH_WINDOW=15 minutes

# Ровно 32 байта: openssl rand -hex 32  ИЛИ  openssl rand -base64 32
# Без переменной — dev-ключ из символов «a» (не для прода).
SESSION_KEY=

# Первый админ (bun run eecli seed:admin):
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password