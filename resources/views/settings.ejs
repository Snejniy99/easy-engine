<h1 class="h3 fw-bold mb-2">Настройки системы</h1>
<p class="text-muted mb-4">Включение и отключение модулей без перезапуска процесса.</p>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-light fw-semibold">Тема сайта (как в WordPress)</div>
    <div class="card-body">
        <p class="text-muted small mb-3">Каталог <code class="small">resources/themes/&lt;slug&gt;/</code>: <code class="small">theme.json</code>, <code class="small">layouts/layout-public.ejs</code>, <code class="small">layouts/layout-panel.ejs</code>, опционально <code class="small">public/style.css</code>. Пустой выбор — из <code class="small">EE_ACTIVE_THEME</code> / <code class="small">EE_PUBLIC_THEME</code> или тема <code class="small">default</code>.</p>
        <% if (typeof themeEffectiveLabel !== 'undefined') { %>
        <p class="small mb-3"><span class="text-muted">Активная тема:</span> <%= themeEffectiveLabel %></p>
        <% } %>
        <form method="post" action="/admin/settings/site-theme" class="row g-3 align-items-end">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="page" value="<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>">
            <div class="col-md-8 col-lg-6">
                <label class="form-label" for="activeThemeSelect">Тема</label>
                <select class="form-select" id="activeThemeSelect" name="activeTheme">
                    <option value=""<%= (typeof themeStored === 'undefined' || themeStored === '') ? ' selected' : '' %>>Автоматически (переменные окружения / default)</option>
                    <% if (typeof engineThemes !== 'undefined') { engineThemes.forEach(function (t) { %>
                    <option value="<%= t.slug %>"<%= (typeof themeStored !== 'undefined' && themeStored === t.slug) ? ' selected' : '' %>><%= t.name %> (<%= t.slug %>)</option>
                    <% }); } %>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Сохранить</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-light fw-semibold d-flex flex-wrap justify-content-between align-items-center gap-2">
        <span>Плагины</span>
        <% if (typeof totalCount !== 'undefined' && totalCount > 0) { %>
        <span class="text-muted small fw-normal">Строки <%= rowFrom %>–<%= rowTo %> из <%= totalCount %></span>
        <% } %>
    </div>
    <% if (typeof plugins !== 'undefined' && plugins.length === 0) { %>
    <div class="card-body text-muted small">Нет установленных плагинов.</div>
    <% } else { %>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col">Название</th>
                    <th scope="col">Путь</th>
                    <th scope="col">Версия</th>
                    <th scope="col">Статус</th>
                    <th scope="col" class="text-end" style="min-width: 12rem">Действия</th>
                </tr>
            </thead>
            <tbody>
                <% plugins.forEach(function (p) { %>
                <tr>
                    <td class="fw-medium"><%= p.name %></td>
                    <td><code class="small text-break">/plugins/<%= p.id %></code></td>
                    <td class="text-muted small"><%= typeof p.version !== 'undefined' && p.version ? p.version : '—' %></td>
                    <td>
                        <% if (p.enabled) { %>
                        <span class="badge text-bg-success">Включён</span>
                        <% } else { %>
                        <span class="badge text-bg-secondary">Выключен</span>
                        <% } %>
                    </td>
                    <td class="text-end">
                        <div class="d-inline-flex flex-wrap gap-1 justify-content-end">
                            <% if (p.hasAdminSettings) { %>
                            <a href="/admin/settings/plugins/<%= p.id %>" class="btn btn-sm btn-outline-primary">Параметры</a>
                            <% } %>
                            <form method="post" action="/admin/settings/plugins/toggle" class="d-inline mb-0">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="pluginId" value="<%= p.id %>">
                                <input type="hidden" name="enabled" value="<%= p.enabled ? '0' : '1' %>">
                                <input type="hidden" name="page" value="<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>">
                                <button type="submit" class="btn btn-sm <%= p.enabled ? 'btn-outline-danger' : 'btn-outline-success' %>">
                                    <%= p.enabled ? 'Отключить' : 'Включить' %>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <nav class="card-footer bg-transparent border-top py-3" aria-label="Страницы списка плагинов">
        <ul class="pagination pagination-sm mb-0 justify-content-center flex-wrap">
            <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                <% if (currentPage <= 1) { %>
                <span class="page-link">Назад</span>
                <% } else { %>
                <a class="page-link" href="/admin/settings?page=<%= currentPage - 1 %>">Назад</a>
                <% } %>
            </li>
            <% for (var pi = 1; pi <= totalPages; pi++) { %>
            <li class="page-item <%= pi === currentPage ? 'active' : '' %>"<% if (pi === currentPage) { %> aria-current="page"<% } %>>
                <a class="page-link" href="/admin/settings?page=<%= pi %>"><%= pi %></a>
            </li>
            <% } %>
            <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                <% if (currentPage >= totalPages) { %>
                <span class="page-link">Вперёд</span>
                <% } else { %>
                <a class="page-link" href="/admin/settings?page=<%= currentPage + 1 %>">Вперёд</a>
                <% } %>
            </li>
        </ul>
    </nav>
    <% } %>
    <% } %>
</div>
