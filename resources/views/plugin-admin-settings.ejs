<div class="mb-4">
    <a href="/admin/settings" class="small text-decoration-none">← К списку плагинов</a>
    <h1 class="h3 fw-bold text-primary mt-2 mb-1"><%= title %></h1>
    <p class="text-muted small mb-0"><code>/plugins/<%= pluginId %></code></p>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form method="post" action="/admin/settings/plugins/<%= pluginId %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <% fields.forEach(function (f) { %>
            <div class="mb-4">
                <label class="form-label fw-medium" for="s_<%= f.key %>"><%= f.label %></label>
                <% if (typeof f.description === 'string' && f.description) { %>
                <div class="form-text mb-1"><%= f.description %></div>
                <% } %>
                <% if ((f.type || 'text') === 'textarea') { %>
                <textarea class="form-control" id="s_<%= f.key %>" name="setting_<%= f.key %>" rows="3"><%= values[f.key] %></textarea>
                <% } else if ((f.type || 'text') === 'number') { %>
                <input class="form-control" type="number" step="any" id="s_<%= f.key %>" name="setting_<%= f.key %>" value="<%= values[f.key] %>">
                <% } else { %>
                <input class="form-control" type="text" id="s_<%= f.key %>" name="setting_<%= f.key %>" value="<%= values[f.key] %>">
                <% } %>
                <div class="form-text">По умолчанию: <code><%= f.defaultValue %></code></div>
            </div>
            <% }) %>
            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <a href="/admin/settings" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
