<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Easy Engine' %></title>
    <link rel="stylesheet" href="/public/css/bootstrap.min.css">
    <% if (typeof themeStyleHref === 'string' && themeStyleHref.length) { %>
    <link rel="stylesheet" href="<%= themeStyleHref %>">
    <% } %>
    <script src="/public/js/htmx.min.js" defer></script>
    <style>
        .htmx-indicator { display: none; }
        .htmx-request .htmx-indicator { display: inline-block; }
        .htmx-request.btn { opacity: 0.7; pointer-events: none; }
        .app-sidebar { box-shadow: 2px 0 12px rgba(0,0,0,0.08); }
        .sidebar-nav .nav-link {
            font-size: 0.875rem;
            padding: 0.45rem 0.75rem;
            border-radius: 0.375rem;
            color: rgba(255,255,255,0.6);
        }
        .sidebar-nav .nav-link:hover { color: #fff; background: rgba(255,255,255,0.08); }
        .sidebar-nav .nav-link.active {
            color: #fff;
            background: rgba(var(--bs-primary-rgb), 0.35);
            box-shadow: inset 3px 0 0 var(--bs-primary);
        }
        .sidebar-nav .nav-link.disabled { opacity: 0.55; font-size: 0.68rem; letter-spacing: 0.06em; text-transform: uppercase; }
    </style>
</head>
<body class="bg-body-secondary">
    <% const path = currentPath; %>
    <% const menuSecs = typeof panelMenuSections !== 'undefined' && panelMenuSections.length ? panelMenuSections : []; %>
    <div class="container-fluid p-0">
        <div class="row g-0 min-vh-100">
            <div class="col-12 col-md-3 col-lg-2 px-0">
                <aside class="app-sidebar d-flex flex-column min-vh-100 bg-dark border-end border-secondary" data-bs-theme="dark">
                    <div class="px-3 py-3 border-bottom border-secondary d-flex align-items-center gap-3">
                        <div class="rounded-3 bg-primary d-flex align-items-center justify-content-center flex-shrink-0 fw-bold text-white" style="width: 2.25rem; height: 2.25rem;">E</div>
                        <div class="min-w-0">
                            <div class="fw-semibold text-white text-truncate">Easy Engine</div>
                            <div class="small text-white-50">Панель</div>
                        </div>
                    </div>
                    <nav class="sidebar-nav flex-grow-1 overflow-y-auto py-3 px-2" aria-label="Меню">
                        <ul class="nav flex-column gap-1">
                            <% menuSecs.forEach(function (sec, si) { %>
                                <% if (sec.label) { %><li class="nav-item <%= si > 0 ? 'mt-2' : '' %>"><span class="nav-link disabled py-1"><%= sec.label %></span></li><% } %>
                                <% sec.nodes.forEach(function (n) { %>
                                    <%- include('partials/panel-menu-node.ejs', { node: n }) %>
                                <% }); %>
                            <% }); %>
                        </ul>
                    </nav>
                    <div class="p-3 mt-auto border-top border-secondary">
                        <div class="rounded-3 p-3 bg-black bg-opacity-25 border border-secondary border-opacity-50">
                            <div class="fw-medium text-white text-truncate small" title="<%= user.username || user.email %>"><%= user.username || user.email %></div>
                            <div class="text-white-50 text-truncate small"><%= user.email %></div>
                            <% if (user.role === 'admin') { %>
                                <span class="badge text-bg-danger mt-2">Админ</span>
                            <% } else if (user.role === 'moderator') { %>
                                <span class="badge text-bg-warning text-dark mt-2">Модератор</span>
                            <% } else { %>
                                <span class="badge text-bg-secondary mt-2">Пользователь</span>
                            <% } %>
                            <form method="post" action="/logout" class="mt-3 mb-0">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" class="btn btn-sm btn-outline-light w-100">Выйти</button>
                            </form>
                        </div>
                    </div>
                </aside>
            </div>
            <div class="col-12 col-md-9 col-lg-10 min-vh-100">
                <main class="p-3 p-md-4">
                    <div class="bg-white border-0 shadow-sm rounded-3 p-3 p-md-4">
                        <%- body %>
                    </div>
                </main>
            </div>
        </div>
    </div>
    <script src="/public/js/bootstrap.bundle.min.js"></script>
</body>
</html>
